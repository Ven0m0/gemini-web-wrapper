{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "default_agent": "plan",
  "share": "manual",
  "permission": {
    "*": "allow",
    "sudo *": "deny",
    "rm -rf /": "deny",
    "rm -rf /*": "deny",
    "rm -rf ~": "deny",
    "rm -rf ~/*": "deny",
    ":(){:|:&}:": "deny",
    "doom_loop": "deny"
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "plugin": [
    "openslimedit@1.0.4",
    "opencode-websearch@0.5.0",
    "opencode-ignore@1.1.0",
    "@nick-vi/opencode-type-inject@1.5.1"
  ],
  "disabled_providers": ["openai"],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      ".venv/**",
      "uv.lock",
      "ocr_debug/**",
      "**/node_modules/**"
    ]
  },
  "experimental": {
    "continue_loop_on_deny": false,
    "batch_tool": true
  },
  "mcp": {
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "ref-tools": {
      "type": "remote",
      "url": "https://api.ref.tools/mcp",
      "enabled": true
    }
  }
}
