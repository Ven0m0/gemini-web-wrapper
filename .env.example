# Google API Key for Gemini
GOOGLE_API_KEY=your_google_api_key_here

# Model Configuration
MODEL_PROVIDER=gemini
MODEL_NAME=gemini-3.1-pro-preview

# Optional Anthropic API Key for Claude models
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional GitHub Copilot token
COPILOT_API_KEY=your_github_copilot_token_here

# Optional Bifrost AI Gateway Configuration
# Bifrost URL (default: http://localhost:8080/v1)
BIFROST_URL=http://localhost:8080/v1
# Bifrost API Key
BIFROST_API_KEY=your_bifrost_api_key_here

# Server Configuration
PORT=9000
FRONTEND_DIST_DIR=frontend/dist

# Development Settings
DEBUG=false
LOG_LEVEL=INFO

# Zagi (agent-optimised git CLI)
# Set to enable agent mode for commit tracking and guardrails.
# Auto-detected in Claude Code, Cursor, Windsurf, and OpenCode.
# ZAGI_AGENT=claude
