# Optional gateway auth key. When set, clients must send Authorization: Bearer <API_KEY>
API_KEY=

# Provider selection
MODEL_PROVIDER=gemini
MODEL_NAME=gemini-3.1-pro-preview

# Provider credentials
GOOGLE_API_KEY=your_google_api_key_here
ANTHROPIC_API_KEY=
COPILOT_API_KEY=
OPENCODE_API_KEY=
KILO_API_KEY=

# Optional provider base URL overrides
COPILOT_BASE_URL=https://api.githubcopilot.com
OPENCODE_BASE_URL=http://localhost:4096/zen/v1
KILO_BASE_URL=https://api.kilo.ai/api/gateway

# Server settings
HOST=0.0.0.0
PORT=9000
CORS_ALLOW_ORIGINS=http://localhost:5173
FRONTEND_DIST_DIR=apps/web/dist

# Repo index settings
REPO_INDEX_ENABLED=true
REPO_INDEX_DB_PATH=.cache/repo-index.db
REPO_INDEX_TURSO_SYNC_URL=
REPO_INDEX_TURSO_AUTH_TOKEN=
REPO_INDEX_MAX_FILES=1000
REPO_INDEX_MAX_FILE_BYTES=262144
REPO_INDEX_BASH_LSP_COMMAND=bash-language-server
REPO_INDEX_PYTHON_LSP_COMMAND=pylsp
REPO_INDEX_RUST_LSP_COMMAND=rust-analyzer
