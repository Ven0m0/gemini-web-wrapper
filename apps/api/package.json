{
  "name": "@affine/api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Affine AI Coding Workstation - TypeScript API",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "build": "npx esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --format=esm",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/generative-ai": "^0.24.0",
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^12.0.0",
    "hono": "^4.6.0",
    "uuid": "^13.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^24.0.0",
    "@types/uuid": "^11.0.0",
    "bun-types": "^1.1.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0"
  }
}
